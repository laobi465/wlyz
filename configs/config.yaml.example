# ============================================================
# KeyAuth SaaS —— 后端配置文件样例
# ============================================================
# 用法：复制到 configs/config.yaml，按需修改
# 敏感字段（AES_KEY / JWT_SECRET）必须从环境变量传入（铁律 04）
# ============================================================

app:
  port: 8080
  mode: release   # debug / release / test

mysql:
  host: mysql       # docker compose 内部域名
  port: 3306
  database: keyauth
  username: keyauth
  password: ""      # 从环境变量 MYSQL_PASSWORD 传入
  max_open_conns: 100
  max_idle_conns: 20

redis:
  host: redis
  port: 6379
  password: ""      # 从环境变量 REDIS_PASSWORD 传入
  db: 0

jwt:
  secret: ""                # 必填：通过 JWT_SECRET 环境变量传入
  expire_hours: 24          # Token 有效期（小时）
  refresh_hours: 168        # 刷新有效期（7 天）
  issuer: keyauth-saas

# 敏感字段：从环境变量传入（铁律 04）
crypto:
  aes_key: ""               # 必填：32 字节，通过 AES_KEY / APP_AES_KEY 环境变量传入
  rsa_private_key_path: /app/keys/rsa_private.pem
  rsa_public_key_path: /app/keys/rsa_public.pem

# 数据库迁移（v0.3.5 新增：server 启动时自动执行）
# 铁律 05：迁移目录路径走配置
migration:
  auto: true                # 启动时是否自动执行迁移
  dir: /app/migrations      # 迁移文件目录（容器内绝对路径）

# 业务域名（用于回调 URL / 邮件链接等）
domain: ""
