# ============================================================
# KeyAuth SaaS —— 后端配置文件样例
# ============================================================
# 用法：复制到 configs/config.yaml，按需修改
# 敏感字段（AES_KEY / JWT_SECRET）必须从环境变量传入（铁律 04）
# ============================================================

app:
  port: 8080
  mode: release   # debug / release / test
  # v0.6.6：端口冲突自动 +1 重试
  # 开发期设为 true：8080 被占用时自动尝试 8081、8082…（最多 port_max_attempts 次）
  # 生产期保持 false：避免端口漂移导致 nginx/反代失配（容器内端口固定 8080）
  # 也可通过环境变量 APP_PORT_AUTO_INCREMENT=true 开启
  port_auto_increment: false
  port_max_attempts: 20  # 最大尝试次数（含起始端口）

mysql:
  host: mysql       # docker compose 内部域名
  port: 3306
  database: keyauth
  username: keyauth
  password: ""      # 从环境变量 MYSQL_PASSWORD 传入
  max_open_conns: 100
  max_idle_conns: 20
  # v0.5.0 读写分离：从库列表（留空表示单库模式）
  # 也可通过环境变量 MYSQL_SLAVES=slave1:3306,slave2:3306 传入
  slaves:
    - host: mysql-slave1
      port: 3306
      # username/password 留空则继承主库
    - host: mysql-slave2
      port: 3306

redis:
  host: redis
  port: 6379
  password: ""      # 从环境变量 REDIS_PASSWORD 传入
  db: 0
  # v0.5.0 Redis 多模式支持（single / sentinel / cluster）
  # mode: single    # 默认单实例模式
  # mode: sentinel  # 哨兵模式（需配置 addrs + master_name）
  # mode: cluster   # 集群模式（需配置 addrs）
  # addrs:          # sentinel/cluster 模式的地址列表
  #   - sentinel1:26379
  #   - sentinel2:26379
  #   - sentinel3:26379
  # master_name: mymaster  # sentinel 模式必填
  # username: ""           # Redis 6+ ACL 用户名（可选）

jwt:
  secret: ""                # 必填：通过 JWT_SECRET 环境变量传入
  expire_hours: 24          # Token 有效期（小时）
  refresh_hours: 168        # 刷新有效期（7 天）
  issuer: keyauth-saas

# 敏感字段：从环境变量传入（铁律 04）
crypto:
  aes_key: ""               # 必填：32 字节，通过 AES_KEY / APP_AES_KEY 环境变量传入
  rsa_private_key_path: /app/keys/rsa_private.pem
  rsa_public_key_path: /app/keys/rsa_public.pem

# 数据库迁移（v0.3.5 新增：server 启动时自动执行）
# 铁律 05：迁移目录路径走配置
migration:
  auto: true                # 启动时是否自动执行迁移
  dir: /app/migrations      # 迁移文件目录（容器内绝对路径）

# 业务域名（用于回调 URL / 邮件链接等）
domain: ""
