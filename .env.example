# ============================================================
# KeyAuth SaaS 环境变量样例
# ============================================================
# 用法：
#   cp .env.example .env
#   修改以下敏感字段后：docker compose up -d
# ============================================================

# ---------- 数据库 MySQL ----------
MYSQL_ROOT_PASSWORD=CHANGE_ME_TO_STRONG_ROOT_PASSWORD
MYSQL_DATABASE=keyauth
MYSQL_USER=keyauth
MYSQL_PASSWORD=CHANGE_ME_TO_STRONG_DB_PASSWORD
MYSQL_PORT=3306

# ---------- Redis ----------
REDIS_PASSWORD=CHANGE_ME_TO_STRONG_REDIS_PASSWORD
REDIS_PORT=6379

# ---------- 后端服务密钥（铁律 04：必须从环境变量传入） ----------
# AES-256 密钥：必须正好 32 字节字符串（不是 base64 解码后 32 字节）
# 生成命令：openssl rand -hex 16  （16 字节随机 → hex 编码 32 字符）
AES_KEY=CHANGE_ME_32_CHARS_AES_KEY_HEX

# JWT 签名密钥：建议使用 openssl rand -hex 32
JWT_SECRET=CHANGE_ME_64_HEX_CHARS_JWT_SECRET

# ---------- 端口 ----------
SERVER_PORT=8080
ADMIN_PORT=8081

# ---------- RSA 密钥对路径 ----------
# 需提前生成：
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:4096 -out keys/rsa_private.pem
#   openssl rsa -in keys/rsa_private.pem -pubout -out keys/rsa_public.pem
# RSA_PRIVATE_KEY_PATH=/app/keys/rsa_private.pem
# RSA_PUBLIC_KEY_PATH=/app/keys/rsa_public.pem
